{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "COMBO-UI Editor",
  "version": "0.1.0",
  "identifier": "es.guillermovalentin.combo-ui-editor",
  "build": {
    "beforeDevCommand": "vp dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "vp build && cd theme-sync-server && pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "COMBO-UI Editor",
        "width": 1600,
        "height": 1400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["theme-sync-server/dist/theme-sync-server.cjs"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
